# Shared example environment variables. Copy relevant sections into
# packages/api/.env, packages/worker/.env, packages/web/.env as needed.

# --- packages/api ---
PORT=4000
DATABASE_URL="file:./data/dev.db"
JWT_SECRET=change-me-in-production
AUTH_USERNAME=admin
# bcrypt hash of the login password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
AUTH_PASSWORD_HASH=$2a$10$Ar7JzAIi8fWs6g3JR/PHduOj4GqI1iSjQqR6ho1bCB0LM6ylv1FJ6
MEDIA_ROOT_DIR=./data/media
MEDIA_PUBLIC_BASE_PATH=/media
# Comma-separated list of allowed CORS origins (e.g. production URL and local dev).
CORS_ORIGIN=http://localhost:5173,https://your-static-webapp.azurestaticapps.net

# --- packages/worker ---
PAAS_API_BASE_URL=https://paas.example.com
PAAS_API_KEY=
POLL_INTERVAL_MS=3000
POLL_TIMEOUT_MS=900000
WORKER_TICK_MS=5000
IMAGE_TO_VIDEO_MODEL=
IMAGE_TO_VIDEO_FPS=
IMAGE_TO_VIDEO_NUM_FRAMES=
IMAGE_TO_VIDEO_RESOLUTION=

# --- packages/web ---
VITE_API_BASE_URL=http://localhost:4000
